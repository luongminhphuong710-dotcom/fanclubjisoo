DATABASE_URL="postgresql://fanclub:fanclub@localhost:5432/fanclub?schema=public"

# Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET="replace-with-a-random-secret"

# Spotify Client Credentials flow.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_MARKET="US"

# YouTube Data API key.
YOUTUBE_API_KEY=""

# X API v2 bearer token, optional for social news ingestion.
X_BEARER_TOKEN=""

# Cloud media storage. Use one provider in production.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
AWS_REGION=""
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
